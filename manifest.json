{
  "manifest_version": 3,
  "name": "Spoiler Shield - Hide Video Durations",
  "version": "1.1.0",
  "description": "Hide YouTube & Twitch video durations, progress bars, thumbnail times & chapter lengths so the clock never spoils the result.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Spoiler Shield",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content/core.js", "content/sites/youtube.js"],
      "css": ["content/sites/youtube.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["content/core.js", "content/sites/twitch.js"],
      "css": ["content/sites/twitch.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
